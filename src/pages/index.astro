---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import GhostContentAPI from '@tryghost/content-api';

// URL del tuo vecchio sito WordPress ancora online per recuperare i media e gli articoli mancanti
const VECCHIO_SITO_WP = "https://ruvolibera.it"; 

let posts = [];

try {
  // 1. Connessione alla VM in Iowa
  const api = new GhostContentAPI({
    url: import.meta.env.GHOST_API_URL || 'http://35.188.52.213:2368',
    key: import.meta.env.GHOST_CONTENT_API_KEY || '',
    version: "v5.0"
  });

  // 2. MODIFICA FONDAMENTALE: Cambiato da limit: 5 a limit: 'all' per leggere TUTTO l'archivio!
  posts = await api.posts.browse({limit: 'all', include: 'tags'});
} catch (e) {
  // SALVAGENTE: Se Netlify non ha le chiavi del file .env, simula l'indice completo pescando i testi principali
  posts = [
    {
      title: "Il futuro ha una nuova velocità.",
      slug: "il-futuro-ha-una-nuova-velocita",
      custom_excerpt: "Abbiamo varato un'architettura tecnologica d'avanguardia e un hosting di nuova generazione, pensati per far correre i contenuti senza perdere l'anima.",
      feature_image: "/content/images/wordpress/2026/04/RuvoLibera-logo-alba-con-riflesso-webp.jpg"
    },
    {
      title: "Here To Stay",
      slug: "here-to-stay",
      custom_excerpt: "RuvoLibera non insegue la cronaca. Ci piacciono i contenuti destinati a restare. Scriviamo insieme la Storia di questa Città.",
      feature_image: ""
    },
    {
      title: "La Forza di Gravità",
      slug: "la-forza-di-gravita",
      custom_excerpt: "Le strisce blu sono state imposte alla nostra Città con una protervia ingiustificabile e con un aspetto punitivo che offende i cittadini.",
      feature_image: ""
    },
    {
      title: "O' Sistema 4. Parole e Potere",
      slug: "o-sistema-4-parole-e-potere",
      custom_excerpt: "Prendiamo in esame la raccolta sedicente differenziata. Se guardiamo i fatti, vediamo un mostro che costringe i cittadini a un superlavoro.",
      feature_image: ""
    }
  ];
}

// 3. Sistemazione dei percorsi immagini per la Home
const fixImageUrl = (url) => {
  if (!url || url.startsWith('/placeholder')) return '/placeholder-about.jpg';
  
  let localUrl = url.replace(/http:\/\/35\.188\.52\.213:2368/g, '');
  
  // Se l'immagine punta alla cartella dei media passata, la reindirizziamo al vecchio sito online
  if (localUrl.startsWith('/content/images/wordpress/')) {
    localUrl = `${VECCHIO_SITO_WP}${localUrl.replace('/content/images/wordpress/', '/wp-content/uploads/')}`;
  }
  
  localUrl = localUrl
    .replace(/-jpg\.webp/g, '.jpg')
    .replace(/-JPG\.webp/g, '.JPG')
    .replace(/-jpeg\.webp/g, '.jpeg')
    .replace(/-JPEG\.webp/g, '.JPEG')
    .replace(/-png\.webp/g, '.png')
    .replace(/-PNG\.webp/g, '.PNG')
    .replace(/-gif\.webp/g, '.gif')
    .replace(/-GIF\.webp/g, '.GIF');
    
  return localUrl;
};
---

<!doctype html>
<html lang="it">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			
			<!-- SEZIONE 1: PERSONAL BRANDING (MINIMALISMO ELEGANTE APPLE) -->
			<section class="branding-section">
				<div class="avatar-placeholder">M</div>
				<h1>Ciao, sono Mario Albrizio</h1>
				<p class="branding-bio">
					Benvenuto nella mia nuova casa digitale. Qui trovi il mio profilo professionale, le mie referenze e il mio intero archivio storico di articoli e inchieste. Scrivo per cercare, scoprire e descrivere l'essenziale nascosto.
				</p>
				<div class="branding-links">
					<a href="/about" class="btn-primary">Scopri il mio Profilo</a>
					<a href="https://linkedin.com" target="_blank" class="btn-secondary">LinkedIn</a>
				</div>
			</section>

			<hr class="section-divider" />

			<!-- SEZIONE 2: ARCHIVIO GIORNALISTICO (STILE SERIO GRANDE GIORNALE) -->
			<section class="journal-section">
				<h2 class="section-title">Ultimi Articoli dall'Archivio</h2>
				<ul class="post-list">
					{posts.map((post) => (
						<li class="post-item">
							<div class="post-image-wrapper">
								<img src={fixImageUrl(post.feature_image)} alt="" />
							</div>
							<div class="post-content">
								<h3 class="post-title-link">
									<a href={`/blog/${post.slug}`}>{post.title}</a>
								</h3>
								<p class="post-excerpt">
									{post.custom_excerpt || post.excerpt?.substring(0, 140)}...
								</p>
							</div>
						</li>
					))}
				</ul>
			</section>

		</main>
		<Footer />
	</body>
</html>

<style is:global>
	/* =========================================================
	   FORZATURA ASSOLUTA STILE APPLE + GRANDE GIORNALE
	   ========================================================= */
	html, body, main, section, div, article, ul, li, header, footer, nav {
		background-color: #fbfbfd !important; /* Bianco opaco riposante */
		background-image: none !important;    /* Polverizza sfumature vecchie */
		box-shadow: none !important;          /* Rimuove ombre pesanti */
		color: #1d1d1f !important;            /* Grigio scurissimo Apple */
	}

	html, body {
		margin: 0 !important;
		padding: 0 !important;
		font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif !important;
		line-height: 1.6 !important;
		-webkit-font-smoothing: antialiased !important;
	}

	main {
		max-width: 700px !important; /* Gabbia centrata aurea */
		margin: 0 auto !important;
		padding: 3rem 1rem !important;
	}

	/* PERSONAL BRANDING STYLE */
	.branding-section { text-align: center !important; padding: 2.5rem 0 1rem 0 !important; }
	.avatar-placeholder {
		width: 80px; height: 80px; background-color: #1d1d1f !important; color: #ffffff !important;
		display: flex; align-items: center; justify-content: center; font-size: 2rem; font-weight: bold;
		border-radius: 50%; margin: 0 auto 1.5rem auto;
	}
	.branding-section h1 { font-size: 2.4rem !important; font-weight: 700 !important; color: #000000 !important; letter-spacing: -0.02em !important; margin: 0 0 1rem 0 !important; }
	.branding-bio { font-size: 1.15rem !important; line-height: 1.7 !important; color: #424245 !important; max-width: 600px; margin: 0 auto 2rem auto !important; }
	.branding-links { display: flex; gap: 1rem; justify-content: center; }
	.btn-primary { background-color: #0071e3 !important; color: #ffffff !important; padding: 0.6rem 1.2rem; border-radius: 20px; font-size: 0.95rem; text-decoration: none; font-weight: 500; }
	.btn-secondary { color: #0066cc !important; padding: 0.6rem 1.2rem; font-size: 0.95rem; text-decoration: none; }
	.btn-secondary:hover { text-decoration: underline; }
	.section-divider { border: 0 !important; border-top: 1px solid #e5e5e7 !important; margin: 3rem 0 !important; }

	/* ELENCO ARTICOLI GIORNALE STYLE */
	.section-title { font-family: "Georgia", Cambria, serif !important; font-size: 1.6rem !important; font-weight: 700 !important; color: #000000 !important; margin-bottom: 2rem !important; border-bottom: 1px solid #e5e5e7; padding-bottom: 0.5rem; }
	.post-list { list-style: none !important; padding: 0 !important; margin: 0 !important; }
	.post-item { display: flex !important; gap: 1.5rem !important; align-items: flex-start !important; margin-bottom: 2.5rem !important; padding-bottom: 2.5rem; border-bottom: 1px solid #e5e5e7; }
	.post-image-wrapper { flex-shrink: 0; }
	.post-item img { width: 140px !important; height: 95px !important; object-fit: cover !important; border-radius: 6px !important; display: block; }
	.post-title-link h3 { font-family: "Georgia", Cambria, serif !important; font-size: 1.35rem !important; font-weight: 700 !important; margin: 0 0 0.5rem 0 !important; line-height: 1.3 !important; }
	.post-title-link a { color: #000000 !important; text-decoration: none; }
	.post-title-link a:hover { color: #0066cc !important; text-decoration: underline; }
	.post-excerpt { font-size: 1rem !important; line-height: 1.5 !important; color: #6e6e73 !important; margin: 0 !important; }
</style>
